# Keep MLTracker image builds small.  The compose file lives in
# src/mltracker but uses the repo root as build context so Docker can
# copy the package root plus mltracker sources.
*

!src/
src/*
!src/__init__.py
!src/foreblocks/
src/foreblocks/*
!src/foreblocks/__init__.py
!src/mltracker/
!src/mltracker/**

src/mltracker/__pycache__/
src/mltracker/**/__pycache__/
src/mltracker/mltracker_data/
src/mltracker/dashboard_v2/node_modules/
src/mltracker/dashboard_v2/dist/
src/mltracker/dashboard_v2/*.tsbuildinfo
src/mltracker/dashboard_v2/build.log
src/mltracker/dashboard_v2/vite.config.d.ts
src/mltracker/dashboard_v2/vite.config.js
